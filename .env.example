# Lokaal: kopieer naar .env en vul in. Nooit committen.
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optioneel (default claude-sonnet-4-6). Goedkoper: claude-haiku-4-5
# ANTHROPIC_MODEL=claude-haiku-4-5
# Optioneel API-poort (default 8787)
# PORT=8787

# Optioneel — cloud sync (zelfde klanten in elke browser): zie README
# SYNC_SECRET=kies-een-lang-geheim-wachtwoord
# Aanbevolen: Supabase (run supabase/schema.sql in SQL Editor, daarna Project URL + service_role key)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Alternatief: Vercel KV / Redis
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Alleen voor productie-build (frontend): absolute URL van je Node API (zonder slash aan het eind)
# VITE_API_BASE_URL=https://jouw-backend.railway.app

# Lokaal: kopieer naar .env en vul in. Nooit committen.
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optioneel (default claude-sonnet-4-6). Goedkoper: claude-haiku-4-5
# ANTHROPIC_MODEL=claude-haiku-4-5
# Optioneel API-poort (default 8787)
# PORT=8787

# Alleen voor productie-build (frontend): absolute URL van je Node API (zonder slash aan het eind)
# VITE_API_BASE_URL=https://jouw-backend.railway.app
